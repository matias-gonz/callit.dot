# Copy this file to `.env` at the repo root and fill in the values.
# `.env` is gitignored. Shell env > .env > hardhat vars file.

# Deployer key for `make deploy-paseo`. 0x-prefixed 32-byte hex.
# Get testnet tokens for its Ethereum address at https://faucet.polkadot.io/
PRIVATE_KEY=

# Optional: used by `make deploy-frontend` if you are deploying via a tool
# that expects a substrate mnemonic (bulletin-deploy, DotNS updates, etc.)
MNEMONIC=

# Optional PredictionMarket tuning (used by all deploy scripts).
# Defaults: 0.1 (native token) bond, 86400s (24h) dispute window.
RESOLUTION_BOND=0.1
DISPUTE_WINDOW=86400

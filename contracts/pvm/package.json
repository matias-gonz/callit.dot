{
  "name": "pvm-proof-of-existence",
  "version": "0.1.0",
  "description": "PVM deployment of the ProofOfExistence contract using Hardhat + resolc + viem",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.ts --network local",
    "deploy:paseo-hub": "npx hardhat run scripts/deploy.ts --network paseoHub",
    "deploy:paseo-hub-papi": "npx hardhat run scripts/deploy-paseo-hub.ts --network paseoHub",
    "fmt": "prettier --write 'contracts/**/*.sol' 'scripts/**/*.ts' 'test/**/*.ts' hardhat.config.ts",
    "fmt:check": "prettier --check 'contracts/**/*.sol' 'scripts/**/*.ts' 'test/**/*.ts' hardhat.config.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-viem": "^2.0.0",
    "@parity/hardhat-polkadot": "0.2.7",
    "@parity/resolc": "1.0.0",
    "@polkadot-labs/hdkd": "^0.0.26",
    "@polkadot-labs/hdkd-helpers": "^0.0.27",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "chai": "^4.3.0",
    "hardhat": "^2.27.0",
    "polkadot-api": "^1.23.3",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "viem": "^2.0.0"
  }
}
